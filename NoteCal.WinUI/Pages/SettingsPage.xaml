<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NoteCal_WinUI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NoteCal_WinUI.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
    <Grid MinWidth="760" Padding="24" RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="设置" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding StatusText}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="10">
                    <FontIcon
                        HorizontalAlignment="Left"
                        FontSize="22"
                        Glyph="&#xE790;" />
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="外观" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="切换应用浅色或深色主题。"
                        TextWrapping="Wrap" />
                    <ComboBox
                        x:Name="ThemeSelector"
                        AutomationProperties.AutomationId="SettingsThemeSelector"
                        Header="主题"
                        SelectedValuePath="Tag"
                        SelectionChanged="ThemeSelector_SelectionChanged">
                        <ComboBoxItem Content="浅色" Tag="light" />
                        <ComboBoxItem Content="深色" Tag="dark" />
                    </ComboBox>
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="10">
                    <FontIcon
                        HorizontalAlignment="Left"
                        FontSize="22"
                        Glyph="&#xE787;" />
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="月历" />
                    <ToggleSwitch
                        AutomationProperties.AutomationId="SettingsShowLunarSwitch"
                        Header="显示农历"
                        IsOn="{Binding ShowLunar, Mode=TwoWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="关闭后，月历日期下方不再显示农历文本。"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="2"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="10">
                    <FontIcon
                        HorizontalAlignment="Left"
                        FontSize="22"
                        Glyph="&#xE71D;" />
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="窗口" />
                    <ToggleSwitch
                        AutomationProperties.AutomationId="SettingsMinimizeToTraySwitch"
                        Header="最小化到托盘"
                        IsOn="{Binding MinimizeToTray, Mode=TwoWay}" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="启用后，点击最小化或关闭都会隐藏到系统托盘。"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border
            Grid.Row="2"
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="10">
                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="数据文件" />
                <TextBlock Text="笔记数据：user\NoteCal_notes.json" />
                <TextBlock Text="设置数据：user\NoteCal_settings.json" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="这些文件位于应用目录下，便于从旧版迁移和本地备份。"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</Page>
